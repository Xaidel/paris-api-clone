ENV=development
SERVICE_NAME=paris-api
HTTP_PORT=9000
HTTP_READ_TIMEOUT=5s
HTTP_WRITE_TIMEOUT=10s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
POSTGRES_DB=paris
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin
DATABASE_URL=postgres://admin:admin@localhost:5432/paris?sslmode=disable
DATABASE_PING_TIMEOUT=5s
LOG_LEVEL=info
LOG_FILE_PATH=tmp/logs/paris-api.jsonl
MIGRATIONS_PATH=internal/infrastructure/db/migrations
STORAGE_PROVIDER=local
LOCAL_TRANSACTION_FILE_PATH=.tx-files
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER=transaction-uploads
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_API_VERSION=
OPENAI_USE_AZURE=false
REACT_CLASSIFICATION_MODEL=gpt-4o-mini
REACT_CLASSIFICATION_BATCH_SIZE=10
REACT_CLASSIFICATION_FLUSH_TIMEOUT=2s
REACT_CLASSIFICATION_CLASSIFIER_FAMILY=react
REACT_CLASSIFICATION_CLASSIFIER_VERSION=v1
REACT_CLASSIFICATION_REQUEST_TIMEOUT=30s
REACT_CLASSIFICATION_MAX_RETRIES=2
REACT_CLASSIFICATION_RETRY_BACKOFF=2s
